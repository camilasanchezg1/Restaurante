/* Reset básico */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* Variables de colores */
:root {
    --primary-color: #c7a17a;
    --background-color: #f9f5f0;
    --dark-color: #151515;
}

/* Estilos generales */
body {
    font-family: 'Poppins', sans-serif;
    background-color: var(--background-color);
    color: var(--dark-color);
    text-align: center;
    padding: 20px;
}

/* Contenedor del menú */
.menu-restaurante {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
}

/* Grid de los platos */
.column-3 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); /* Se ajusta automáticamente */
    gap: 20px;
    width: 90%;
    max-width: 1200px;
    margin: 0 auto;
}

/* Tarjetas de los platos */
.plato {
    background: white;
    padding: 15px;
    border-radius: 10px;
    box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.2);
    transition: transform 0.3s ease;
}

.plato:hover {
    transform: translateY(-5px);
}

/* Imágenes de los platos */
.plato img {
    width: 100%;
    max-width: 100%;
    height: auto;
    aspect-ratio: 4/3; /* Mantiene la proporción sin distorsión */
    object-fit: cover;
    border-radius: 10px;
}

/* Texto del plato */
.plato h3 {
    font-size: 1.8rem;
    margin-top: 10px;
    color: var(--primary-color);
}

.plato p {
    font-size: 1.4rem;
    color: var(--dark-color);
    padding: 5px 10px;
}

/* Precio del plato */
.plato strong {
    font-size: 1.6rem;
    color: var(--primary-color);
}

/* Responsividad */
@media (max-width: 768px) {
    .column-3 {
        grid-template-columns: repeat(2, 1fr); /* 2 columnas en tablets */
    }
}

@media (max-width: 480px) {
    .column-3 {
        grid-template-columns: repeat(1, 1fr); /* 1 columna en móviles */
    }
}

body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
    background-color: #f8f8f8;
}
.menu-container {
    width: 90%;
    max-width: 1200px;
    margin: 20px auto;
}
.section-title {
    font-size: 24px;
    font-weight: bold;
    margin-bottom: 10px;
}
.menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    justify-content: center;
    gap: 20px;

}
.menu-item {
    background: white;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
}
.menu-item img {
    width: 100%;
    height: 180px;
    object-fit: cover;
}
.menu-item-content {
    padding: 15px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex-grow: 1;
}
.menu-item h4 {
    margin: 0 0 5px;
    font-size: 18px;
}
.menu-item p {
    margin: 0 0 10px;
    font-size: 14px;
    color: #555;
}
.menu-item .price {
    font-weight: bold;
    font-size: 16px;
    color: #e74c3c;
}

